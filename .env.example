# =============================================================================
# RC7 Programming Assistant — Variables de Entorno
#
# Plantilla ÚNICA: sirve tanto para esta máquina como para un servidor. Copiar a
# .env y completar los valores marcados con "replace_me". El .env NUNCA se
# versiona.
#
#   cp .env.example .env
#
# Esta plantilla NO es configuración activa: el stack solo carga .env (ambos
# docker-compose). Las líneas comentadas documentan el default del código —
# descomentar solo para sobrescribirlo.
#
# ── Qué cambia en un servidor ────────────────────────────────────────────────
#   APP_ENV=production          → activa la validación de secretos: api y worker
#                                 ABORTAN el arranque si algún valor sigue siendo
#                                 el default o es débil (replace_me, postgres,
#                                 minioadmin, vacío).
#   CORS_ORIGINS                → obligatorio, con el dominio público. En JSON.
#   POSTGRES_PASSWORD           → contraseña fuerte (el default "postgres" aborta).
#   MINIO_ROOT_USER/PASSWORD    → credenciales propias (el default aborta).
#   JWT_SECRET                  → openssl rand -hex 32
#   BOOTSTRAP_ADMIN_PASSWORD    → contraseña fuerte
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
PROJECT_NAME=rc7_programming_assistant
# development | production  (ver la nota de arriba)
APP_ENV=development

# -----------------------------------------------------------------------------
# Admin bootstrap
# El primer usuario administrador se crea automáticamente al arrancar si no existe
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=replace_me
BOOTSTRAP_ADMIN_PASSWORD=replace_me
BOOTSTRAP_ADMIN_NAME=Administrador RC7

# -----------------------------------------------------------------------------
# Sesión y autenticación JWT
# -----------------------------------------------------------------------------
# Generar con: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_long_random_secret_min_32_chars
# Algoritmo JWT — no cambiar salvo que se migre explícitamente
# JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=rc7_session
# Duración de la sesión en minutos (720 = 12 horas)
SESSION_TTL_MINUTES=720

# -----------------------------------------------------------------------------
# CORS
# SIEMPRE en formato JSON, incluso con un solo origen: cors_origins es list[str]
# y un string plano aborta el arranque con SettingsError. En production no puede
# contener localhost.
# -----------------------------------------------------------------------------
# CORS_ORIGINS=["http://localhost:3000"]        # desarrollo (es el default)
# CORS_ORIGINS=["https://tudominio.com"]        # servidor

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rc7_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# MinIO (object storage S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_MANUALS=rc7-manuals

# -----------------------------------------------------------------------------
# Google Gemini
# Sin esta clave el chat no responde y la ingestión falla: es el flujo central.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=replace_me
# Modelos Gemini (aplican a API y worker). Centralizados en rc7_shared_config;
# descomentar para sobrescribir. GEMINI_EMBED_DIM debe coincidir con la columna
# vector(N) y con la dimensión que produce el modelo de embeddings.
# GEMINI_GEN_MODEL=gemini-3.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-2
# GEMINI_EMBED_DIM=3072
# Tiempo máximo de espera para llamadas a Gemini (segundos). Mismo default en API
# y worker. Ajustar si se observan timeouts.
# GEMINI_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Chat / SSE
# -----------------------------------------------------------------------------
# Habilita SSE streaming en /api/v1/chat/generate
# Deshabilitar si el SDK de Gemini no soporta streaming en el entorno actual
ENABLE_STREAMING=true

# -----------------------------------------------------------------------------
# Worker — ingestión documental
# Los defaults del código ya están dimensionados para revisar el manual COMPLETO;
# son apropiados tal cual en un servidor. Bajar la cobertura solo para reducir costo.
# -----------------------------------------------------------------------------
# Intervalo de polling para detectar manuales pendientes (segundos)
# WORKER_POLL_INTERVAL_SECONDS=5
# Timeout base por manual (segundos). Dimensionado para que revisar TODOS los
# chunks no falle por timeout: el manual más grande del corpus tiene ~1100 chunks
# y cada revisión es una llamada secuencial a Gemini.
# WORKER_MANUAL_TIMEOUT_SECONDS=7200
# Cobertura base para el cálculo de timeout dinámico (MB)
# WORKER_MANUAL_TIMEOUT_BASE_COVERAGE_MB=8
# Segundos extra por MB adicional en el cálculo de timeout
# WORKER_MANUAL_TIMEOUT_EXTRA_PER_MB_SECONDS=30
# Timeout máximo absoluto por manual (segundos). Tope alto para que el cálculo
# dinámico nunca recorte por debajo de lo que tarda el manual más pesado.
# WORKER_MANUAL_TIMEOUT_MAX_SECONDS=21600
# Habilita la revisión semántica de chunks con Gemini
# SEMANTIC_REVIEW_ENABLED=true
# Fracción de chunks revisados por manual (0.0–1.0). 1.0 = TODOS, sin muestreo.
# SEMANTIC_REVIEW_SAMPLE_RATE=1.0
# Longitud mínima de un chunk para ser elegible a revisión (chars)
# SEMANTIC_REVIEW_MIN_CHARS=250
# Longitud máxima de un chunk para ser elegible a revisión (chars).
# INERTE con el valor por defecto: build_text_chunks corta a 1200 chars, así que
# ningún chunk llega a 2200 y la razón de selección "too_long" nunca se dispara.
# Solo tiene efecto si se baja por debajo de 1200.
# SEMANTIC_REVIEW_MAX_CHARS=2200
# Aplica correcciones automáticas seguras (merge/split/regenerate) tras la revisión
# SEMANTIC_REVIEW_AUTOFIX_ENABLED=true
# Solo se reescribe (regenerate, 1 llamada Gemini/chunk) si la coherencia es ≤ este valor
# SEMANTIC_REVIEW_REGENERATE_MAX_COHERENCE=0.5
# Máximo de chunks revisados por manual (protección de costo). 0 = sin tope.
# SEMANTIC_REVIEW_MAX_REVIEWS_PER_MANUAL=0

# -----------------------------------------------------------------------------
# Frontend — Next.js
# El servicio `web` NO carga este archivo: sus variables las fija el compose
# directamente (INTERNAL_API_URL=http://api:8000). Ponerlas aquí no tiene efecto.
# NEXT_PUBLIC_API_BASE_URL se inlinea en tiempo de build; hoy va vacía a propósito
# para que el navegador use el proxy interno de Next.js.
# -----------------------------------------------------------------------------
