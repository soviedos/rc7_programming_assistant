# =============================================================================
# RC7 Programming Assistant — Variables de Entorno
# Copiar a .env y completar los valores marcados con "replace_me"
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
PROJECT_NAME=rc7_programming_assistant
# Entorno de ejecución: development | production
# En production se validan JWT_SECRET, POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD y GEMINI_API_KEY
APP_ENV=development

# -----------------------------------------------------------------------------
# Admin bootstrap
# El primer usuario administrador se crea automáticamente al arrancar si no existe
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=replace_me
BOOTSTRAP_ADMIN_PASSWORD=replace_me
BOOTSTRAP_ADMIN_NAME=Administrador RC7

# -----------------------------------------------------------------------------
# Sesión y autenticación JWT
# -----------------------------------------------------------------------------
JWT_SECRET=replace_me_with_a_long_random_secret_min_32_chars
# Algoritmo JWT — no cambiar salvo que se migre explícitamente
# JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=rc7_session
# Duración de la sesión en minutos (720 = 12 horas)
SESSION_TTL_MINUTES=720

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rc7_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# MinIO (object storage S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_MANUALS=rc7-manuals

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
GEMINI_API_KEY=replace_me

# -----------------------------------------------------------------------------
# Chat / SSE
# -----------------------------------------------------------------------------
# Activa SSE streaming en POST /api/v1/chat/generate
# false → respuesta JSON síncrona; true → Server-Sent Events (recomendado)
ENABLE_STREAMING=true

# -----------------------------------------------------------------------------
# CORS (opcional — solo si el frontend corre en un origen diferente al default)
# Formato JSON: '["http://localhost:3000","https://mi-dominio.com"]'
# -----------------------------------------------------------------------------
# CORS_ORIGINS=["http://localhost:3000"]
