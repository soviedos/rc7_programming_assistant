# =============================================================================
# RC7 Programming Assistant — Variables de Entorno
# Copiar a .env y completar los valores marcados con "replace_me"
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
PROJECT_NAME=rc7_programming_assistant
# Entorno de ejecución: development | production
# En production se validan JWT_SECRET, POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD y GEMINI_API_KEY
APP_ENV=development

# -----------------------------------------------------------------------------
# Admin bootstrap
# El primer usuario administrador se crea automáticamente al arrancar si no existe
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=replace_me
BOOTSTRAP_ADMIN_PASSWORD=replace_me
BOOTSTRAP_ADMIN_NAME=Administrador RC7

# -----------------------------------------------------------------------------
# Sesión y autenticación JWT
# -----------------------------------------------------------------------------
JWT_SECRET=replace_me_with_a_long_random_secret_min_32_chars
# Algoritmo JWT — no cambiar salvo que se migre explícitamente
# JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=rc7_session
# Duración de la sesión en minutos (720 = 12 horas)
SESSION_TTL_MINUTES=720

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rc7_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------

# MinIO (object storage S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_MANUALS=rc7-manuals

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
GEMINI_API_KEY=replace_me
# Tiempo máximo de espera para llamadas a Gemini (segundos). La API usa 300 s por
# defecto; el worker usa 8 s por defecto. Ajustar si se observan timeouts.
# GEMINI_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Chat / SSE
# -----------------------------------------------------------------------------
# Habilita SSE streaming en /api/v1/chat/generate
# Deshabilitar si el SDK de Gemini no soporta streaming en el entorno actual
ENABLE_STREAMING=true

# -----------------------------------------------------------------------------
# Worker — ingestión documental
# -----------------------------------------------------------------------------
# Intervalo de polling para detectar manuales pendientes (segundos)
# WORKER_POLL_INTERVAL_SECONDS=5
# Timeout base por manual (segundos)
# WORKER_MANUAL_TIMEOUT_SECONDS=420
# Cobertura base para el cálculo de timeout dinámico (MB)
# WORKER_MANUAL_TIMEOUT_BASE_COVERAGE_MB=8
# Segundos extra por MB adicional en el cálculo de timeout
# WORKER_MANUAL_TIMEOUT_EXTRA_PER_MB_SECONDS=30
# Timeout máximo absoluto por manual (segundos)
# WORKER_MANUAL_TIMEOUT_MAX_SECONDS=1800
# Modelo Gemini usado por el worker para revisión semántica y re-chunking
# GEMINI_MODEL=gemini-2.5-flash
# Habilita la revisión semántica de chunks con Gemini
# SEMANTIC_REVIEW_ENABLED=true
# Fracción de chunks revisados por manual (0.0–1.0; 0.1 = 10 %)
# SEMANTIC_REVIEW_SAMPLE_RATE=0.1
# Longitud mínima de un chunk para ser elegible a revisión (chars)
# SEMANTIC_REVIEW_MIN_CHARS=250
# Longitud máxima de un chunk para ser elegible a revisión (chars)
# SEMANTIC_REVIEW_MAX_CHARS=2200
# Aplica correcciones automáticas seguras (merge/split) tras la revisión
# SEMANTIC_REVIEW_AUTOFIX_ENABLED=true
# Máximo de chunks revisados por manual (protección de costo)
# SEMANTIC_REVIEW_MAX_REVIEWS_PER_MANUAL=100

# -----------------------------------------------------------------------------
# Frontend — Next.js
# -----------------------------------------------------------------------------
# URL interna del backend usada por el proxy de Next.js (server-side)
# En Docker Compose el contenedor api es alcanzable como http://api:8000
# INTERNAL_API_URL=http://api:8000
# URL pública de la API, usada en llamadas client-side (dejar vacío para usar proxy Next.js)
# NEXT_PUBLIC_API_BASE_URL=
# Orígenes adicionales permitidos en desarrollo (lista separada por comas)
# NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# CORS (opcional — solo si el frontend corre en un origen diferente al default)
# Formato JSON: '["http://localhost:3000","https://mi-dominio.com"]'
# -----------------------------------------------------------------------------
# CORS_ORIGINS=["http://localhost:3000"]
