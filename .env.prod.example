# ─────────────────────────────────────────────────────────────────────────────
# RC7 Programming Assistant — Production Environment Template
#
# Copy this file to .env on the server and fill in all values.
# NEVER commit .env to the repository.
#
# Generate JWT_SECRET with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Application
PROJECT_NAME=rc7_programming_assistant
APP_ENV=production
BOOTSTRAP_ADMIN_EMAIL=admin@tudominio.com
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrador RC7
SESSION_COOKIE_NAME=rc7_session
SESSION_TTL_MINUTES=720

# Security — generate with: openssl rand -hex 32
JWT_SECRET=

# CORS — must match the public domain (no trailing slash, no localhost)
# Siempre en formato JSON, incluso con un solo origen: cors_origins es list[str] y
# un string plano aborta el arranque con SettingsError.
CORS_ORIGINS=["https://tudominio.com"]

# PostgreSQL
POSTGRES_DB=rc7_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MinIO — change from default credentials
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET_MANUALS=rc7-manuals
MINIO_ENDPOINT=http://minio:9000

# Google Gemini
GEMINI_API_KEY=
# Modelos (API + worker). GEMINI_EMBED_DIM debe ser idéntico en API y worker y
# coincidir con la columna vector(N); el modelo de embeddings produce esa dimensión.
# GEMINI_GEN_MODEL=gemini-3.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-2
# GEMINI_EMBED_DIM=3072
# GEMINI_TIMEOUT_SECONDS=300

# Chat / SSE
# Habilita SSE streaming en /api/v1/chat/generate
# Deshabilitar si el SDK de Gemini no soporta streaming en el entorno actual
ENABLE_STREAMING=true

# Worker — ingestión documental (valores por defecto son apropiados para producción)
# WORKER_POLL_INTERVAL_SECONDS=5
# WORKER_MANUAL_TIMEOUT_SECONDS=7200
# WORKER_MANUAL_TIMEOUT_BASE_COVERAGE_MB=8
# WORKER_MANUAL_TIMEOUT_EXTRA_PER_MB_SECONDS=30
# WORKER_MANUAL_TIMEOUT_MAX_SECONDS=21600
# (modelos Gemini configurados arriba: GEMINI_GEN_MODEL / GEMINI_EMBED_MODEL)
# SEMANTIC_REVIEW_ENABLED=true
# La revisión semántica cubre el manual completo: 1.0 = todos los chunks, 0 = sin tope.
# SEMANTIC_REVIEW_SAMPLE_RATE=1.0
# SEMANTIC_REVIEW_MAX_REVIEWS_PER_MANUAL=0
# SEMANTIC_REVIEW_AUTOFIX_ENABLED=true

# Frontend — Next.js
# URL interna del backend (server-side proxy)
INTERNAL_API_URL=http://api:8000
# NEXT_PUBLIC_API_BASE_URL=
